# Copy to `.env` and adjust for your environment.

# Base URL of the deployed Notes app (UI + API share the same host).
BASE_URL=http://localhost:4444

# MailHog HTTP API (used to read sign-up confirmation emails).
MAILHOG_URL=http://localhost:8025

# Optional: set a fixed Faker seed for fully reproducible test data.
# FAKER_SEED=12345

# MySQL gray-box seam — used ONLY by `npm run test:db` (`@db`-tagged tests).
# Defaults match the app's own compose.yaml dev database; adjust if yours differs.
# DB_HOST=127.0.0.1
# DB_PORT=33444
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=qa_task_dev
