{
  "name": "ps-aqa-tests",
  "version": "1.0.0",
  "description": "API + E2E automated test suite for the Symfony Notes application (Senior AQA tech task)",
  "private": true,
  "scripts": {
    "test": "playwright test --project=api --project=e2e",
    "test:smoke": "playwright test --project=smoke",
    "test:regression": "playwright test --project=regression",
    "test:db": "playwright test --project=db",
    "test:api": "playwright test --project=api",
    "test:e2e": "playwright test --project=e2e",
    "test:headed": "playwright test --project=e2e --headed",
    "test:ui": "playwright test --ui",
    "report": "playwright show-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "typecheck": "tsc --noEmit",
    "install:browsers": "playwright install --with-deps chromium"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.3.0",
    "@playwright/test": "^1.49.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.0",
    "allure-commandline": "^2.43.0",
    "allure-playwright": "^3.10.2",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.7",
    "mysql2": "^3.22.5",
    "typescript": "^5.7.0"
  }
}
